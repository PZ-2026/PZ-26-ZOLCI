<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="32dp"
        android:gravity="center_horizontal">

        <!-- ===== LOGO SECTION ===== -->

        <!-- Logo icon (placeholder - replace with actual drawable) -->
        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:contentDescription="TrainIT logo"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_logo" />

        <!-- App name: Train(white)IT(yellow) -->
        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="TrainIT"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:fontFamily="sans-serif-black" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Twój osobisty trener w kieszeni"
            android:textSize="14sp"
            android:textColor="@color/text_secondary" />

        <!-- ===== TAB SELECTOR (Logowanie / Rejestracja) ===== -->

        <LinearLayout
            android:id="@+id/tabContainer"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="32dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_tab_container"
            android:padding="4dp">

            <!-- Active tab: Logowanie -->
            <TextView
                android:id="@+id/tabLogin"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Logowanie"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:background="@drawable/bg_tab_active" />

            <!-- Inactive tab: Rejestracja -->
            <TextView
                android:id="@+id/tabRegister"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Rejestracja"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:background="@android:color/transparent" />

        </LinearLayout>

        <!-- ============================================= -->
        <!-- ===== LOGIN FORM (visible by default) ======= -->
        <!-- ============================================= -->

        <LinearLayout
            android:id="@+id/loginFormContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- Email field -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Email"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilEmail"
                style="@style/Widget.TrainIT.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:startIconDrawable="@drawable/ic_email"
                app:startIconTint="@color/text_secondary"
                app:hintEnabled="false"
                app:boxBackgroundColor="@color/input_background"
                app:boxStrokeColor="@color/input_stroke"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="jan@example.com"
                    android:textColorHint="@color/hint_color"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:inputType="textEmailAddress"
                    android:background="@android:color/transparent" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password field -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Has\u0142o"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPassword"
                style="@style/Widget.TrainIT.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:startIconDrawable="@drawable/ic_lock"
                app:startIconTint="@color/text_secondary"
                app:endIconMode="password_toggle"
                app:endIconTint="@color/text_secondary"
                app:hintEnabled="false"
                app:boxBackgroundColor="@color/input_background"
                app:boxStrokeColor="@color/input_stroke"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022"
                    android:textColorHint="@color/hint_color"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:inputType="textPassword"
                    android:background="@android:color/transparent" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Forgot password link -->
            <TextView
                android:id="@+id/tvForgotPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="8dp"
                android:text="Zapomnia\u0142e\u015b has\u0142a?"
                android:textSize="13sp"
                android:textColor="@color/accent_yellow"
                android:clickable="true"
                android:focusable="true" />

            <!-- Login button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:text="Zaloguj si\u0119"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:textAllCaps="false"
                app:backgroundTint="@color/accent_yellow"
                app:cornerRadius="28dp"
                app:rippleColor="@color/button_ripple" />

        </LinearLayout>

        <!-- ============================================= -->
        <!-- ===== REGISTER FORM (hidden by default) ===== -->
        <!-- ============================================= -->

        <LinearLayout
            android:id="@+id/registerFormContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Name field -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Imi\u0119 i nazwisko"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilName"
                style="@style/Widget.TrainIT.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:startIconDrawable="@drawable/ic_person"
                app:startIconTint="@color/text_secondary"
                app:hintEnabled="false"
                app:boxBackgroundColor="@color/input_background"
                app:boxStrokeColor="@color/input_stroke"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="Jan Kowalski"
                    android:textColorHint="@color/hint_color"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:inputType="textPersonName"
                    android:background="@android:color/transparent" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Email field -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Email"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilRegEmail"
                style="@style/Widget.TrainIT.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:startIconDrawable="@drawable/ic_email"
                app:startIconTint="@color/text_secondary"
                app:hintEnabled="false"
                app:boxBackgroundColor="@color/input_background"
                app:boxStrokeColor="@color/input_stroke"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRegEmail"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="jan@example.com"
                    android:textColorHint="@color/hint_color"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:inputType="textEmailAddress"
                    android:background="@android:color/transparent" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password field -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Has\u0142o"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilRegPassword"
                style="@style/Widget.TrainIT.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:startIconDrawable="@drawable/ic_lock"
                app:startIconTint="@color/text_secondary"
                app:endIconMode="password_toggle"
                app:endIconTint="@color/text_secondary"
                app:hintEnabled="false"
                app:boxBackgroundColor="@color/input_background"
                app:boxStrokeColor="@color/input_stroke"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRegPassword"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022"
                    android:textColorHint="@color/hint_color"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:inputType="textPassword"
                    android:background="@android:color/transparent" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Register button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegister"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:text="Utw\u00f3rz konto"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:textAllCaps="false"
                app:backgroundTint="@color/accent_yellow"
                app:cornerRadius="28dp"
                app:rippleColor="@color/button_ripple" />

        </LinearLayout>

        <!-- ===== DIVIDER "lub kontynuuj z" ===== -->

        <!-- ===== SOCIAL LOGIN BUTTONS ===== -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"/>

        <!-- ===== BOTTOM LINKS ===== -->

        <!-- Shown on login form: "Nie masz jeszcze konta? Zarejestruj się" -->
        <TextView
            android:id="@+id/tvRegisterLink"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Nie masz jeszcze konta? Zarejestruj si\u0119"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:visibility="visible"
            android:clickable="true"
            android:focusable="true" />

        <!-- Shown on register form: "Masz już konto? Zaloguj się" -->
        <TextView
            android:id="@+id/tvLoginLink"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Masz ju\u017c konto? Zaloguj si\u0119"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</ScrollView>
