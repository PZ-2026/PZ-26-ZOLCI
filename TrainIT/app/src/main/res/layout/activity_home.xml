<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <!-- Scrollable content area -->
    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp">

            <!-- ===== HEADER: Logo + greeting ===== -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Logo -->
                <ImageView
                    android:id="@+id/ivHeaderLogo"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_avatar"
                    android:contentDescription="Avatar użytkownika"
                    android:scaleType="centerCrop" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:id="@+id/tvHeaderAppName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TrainIT"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Witaj z powrotem!"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary" />

                </LinearLayout>

            </LinearLayout>

            <!-- ===== WEEKLY GOAL CARD ===== -->

            <LinearLayout
                android:id="@+id/cardWeeklyGoal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_weekly_goal"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp">

                <!-- Left side: text -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cel tygodniowy"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvWeeklyGoalProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="4/5 trening\u00f3w"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/white" />

                    <!-- Sub-info with check icon -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_check_circle"
                            android:contentDescription="check" />

                        <TextView
                            android:id="@+id/tvWeeklyGoalHint"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="Jeszcze 1 trening do celu!"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Right side: circular progress -->
                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/progressWeekly"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_marginStart="12dp"
                    android:progress="80"
                    app:indicatorColor="@color/progress_indicator"
                    app:trackColor="@color/progress_track"
                    app:trackThickness="6dp"
                    app:indicatorSize="64dp" />

                <!-- Percentage text overlaid on progress (handled in code) -->

            </LinearLayout>

            <!-- Percentage overlay for progress ring -->
            <!-- We'll use a FrameLayout wrapper in code, or position via ConstraintLayout -->

            <!-- ===== STATS GRID (2x2) ===== -->

            <!-- Row 1: Seria dni | Ten tydzień -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <!-- Stat: Seria dni -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_card_dark"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Icon row + badge -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_fire"
                            android:contentDescription="streak" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="\u2197 +2"
                            android:textSize="11sp"
                            android:textColor="@color/stat_badge_green"
                            android:background="@drawable/bg_stat_badge" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Seria dni"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvStatStreak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="12"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/white" />

                </LinearLayout>

                <!-- Stat: Ten tydzień -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_card_dark"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_calendar"
                            android:contentDescription="week" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="\u2197 80%"
                            android:textSize="11sp"
                            android:textColor="@color/stat_badge_green"
                            android:background="@drawable/bg_stat_badge" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Ten tydzie\u0144"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvStatWeek"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="4 dni"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/white" />

                </LinearLayout>

            </LinearLayout>

            <!-- Row 2: Łącznie | Ukończone -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <!-- Stat: Łącznie (hours) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_card_dark"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_clock"
                            android:contentDescription="total time" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="\u2197 +5h"
                            android:textSize="11sp"
                            android:textColor="@color/stat_badge_green"
                            android:background="@drawable/bg_stat_badge" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="\u0141\u0105cznie"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvStatTotalHours"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="48h"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/white" />

                </LinearLayout>

                <!-- Stat: Ukończone -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_card_dark"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_trophy"
                            android:contentDescription="completed" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="\u2197 +4"
                            android:textSize="11sp"
                            android:textColor="@color/stat_badge_green"
                            android:background="@drawable/bg_stat_badge" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Uko\u0144czone"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvStatCompleted"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="156"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/white" />

                </LinearLayout>

            </LinearLayout>

            <!-- ===== RECENT ACTIVITY SECTION ===== -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ostatnia aktywno\u015b\u0107"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/white" />

                <TextView
                    android:id="@+id/tvSeeAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Zobacz wszystkie"
                    android:textSize="13sp"
                    android:textColor="@color/accent_yellow"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- Activity card: Trening górnej partii -->
            <LinearLayout
                android:id="@+id/cardRecentActivity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_card_dark"
                android:orientation="vertical"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <!-- Title row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvActivityTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Trening g\u00f3rnej partii"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/white" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_trending_up"
                        android:contentDescription="trend" />

                </LinearLayout>

                <!-- Meta row: date + duration -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_flash"
                        android:contentDescription="date" />

                    <TextView
                        android:id="@+id/tvActivityDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="Dzisiaj, 18:30"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary" />

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginStart="16dp"
                        android:src="@drawable/ic_clock"
                        android:contentDescription="duration" />

                    <TextView
                        android:id="@+id/tvActivityDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="1h 15min"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary" />

                </LinearLayout>

                <!-- Exercise count + progress dots -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvExerciseCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="8 \u0107wicze\u0144"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary" />

                    <!-- Progress dots -->
                    <LinearLayout
                        android:id="@+id/dotsContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:orientation="horizontal">

                        <!-- 8 dots: first 5 completed (yellow), last 3 empty -->
                        <View
                            android:layout_width="20dp"
                            android:layout_height="6dp"
                            android:layout_marginEnd="3dp"
                            android:background="@color/dot_completed" />
                        <View
                            android:layout_width="20dp"
                            android:layout_height="6dp"
                            android:layout_marginEnd="3dp"
                            android:background="@color/dot_completed" />
                        <View
                            android:layout_width="20dp"
                            android:layout_height="6dp"
                            android:layout_marginEnd="3dp"
                            android:background="@color/dot_completed" />
                        <View
                            android:layout_width="20dp"
                            android:layout_height="6dp"
                            android:layout_marginEnd="3dp"
                            android:background="@color/dot_completed" />
                        <View
                            android:layout_width="20dp"
                            android:layout_height="6dp"
                            android:layout_marginEnd="3dp"
                            android:background="@color/dot_completed" />
                        <View
                            android:layout_width="20dp"
                            android:layout_height="6dp"
                            android:layout_marginEnd="3dp"
                            android:background="@color/dot_empty" />
                        <View
                            android:layout_width="20dp"
                            android:layout_height="6dp"
                            android:layout_marginEnd="3dp"
                            android:background="@color/dot_empty" />
                        <View
                            android:layout_width="20dp"
                            android:layout_height="6dp"
                            android:background="@color/dot_empty" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- ===== BOTTOM NAVIGATION ===== -->

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bottom_nav_bg"
        app:itemIconTint="@color/bottom_nav_color_selector"
        app:itemTextColor="@color/bottom_nav_color_selector"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
