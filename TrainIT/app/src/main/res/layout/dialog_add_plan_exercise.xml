<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:fillViewport="true"
    android:paddingStart="20dp"
    android:paddingTop="8dp"
    android:paddingEnd="20dp"
    android:paddingBottom="12dp"
    android:scrollbars="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ćwiczenie"
            app:boxBackgroundColor="@color/card_dark"
            app:boxStrokeColor="@color/accent_yellow"
            app:hintTextColor="@color/text_secondary">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/acExerciseName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:inputType="none"
                android:popupBackground="@color/card_dark"
                android:textColor="@color/white"
                android:textColorHint="@color/hint_color" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:hint="Serie"
            app:boxBackgroundColor="@color/card_dark"
            app:boxStrokeColor="@color/accent_yellow"
            app:hintTextColor="@color/text_secondary">

            <EditText
                android:id="@+id/etSets"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:inputType="number"
                android:text="3"
                android:textColor="@color/white"
                android:textColorHint="@color/hint_color" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:hint="Powtórzenia"
            app:boxBackgroundColor="@color/card_dark"
            app:boxStrokeColor="@color/accent_yellow"
            app:hintTextColor="@color/text_secondary">

            <EditText
                android:id="@+id/etReps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:inputType="number"
                android:text="10"
                android:textColor="@color/white"
                android:textColorHint="@color/hint_color" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:hint="Ciężar (kg, opcjonalnie)"
            app:boxBackgroundColor="@color/card_dark"
            app:boxStrokeColor="@color/accent_yellow"
            app:hintTextColor="@color/text_secondary">

            <EditText
                android:id="@+id/etWeight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:inputType="numberDecimal"
                android:textColor="@color/white"
                android:textColorHint="@color/hint_color" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:hint="Czas ćwiczenia (s, opcjonalnie)"
            app:boxBackgroundColor="@color/card_dark"
            app:boxStrokeColor="@color/accent_yellow"
            app:hintTextColor="@color/text_secondary">

            <EditText
                android:id="@+id/etDuration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:inputType="number"
                android:textColor="@color/white"
                android:textColorHint="@color/hint_color" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>
</ScrollView>
